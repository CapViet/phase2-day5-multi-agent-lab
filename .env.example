# LLM backend selector: auto | openai | ollama | mock
# auto -> OpenAI if a key is set, else a reachable local Ollama, else the offline mock.
LLM_PROVIDER=auto

# Required only when using the hosted OpenAI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local Ollama (OpenAI-compatible). Switch model by changing OLLAMA_MODEL.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# Optional tracing providers
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional search provider
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
